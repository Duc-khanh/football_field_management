<!DOCTYPE html>
<html lang="vi" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>Thêm sân bóng</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
</head>
<body class="container mt-4">

<h2 th:text="${cour.courId != null ? 'Chỉnh sửa sân bóng' : 'Thêm sân bóng mới'}"></h2>

<form th:action="${cour.courId != null} ? @{/cour/edit/{id}(id=${cour.courId})} : @{/cour/create}"
      method="post" th:object="${cour}" enctype="multipart/form-data">


    <!-- Tên sân -->
    <div class="mb-3">
        <label class="form-label">Tên sân</label>
        <input type="text" th:field="*{courName}" class="form-control"/>
    </div>

    <!-- Giá thuê -->
    <div class="mb-3">
        <label class="form-label">Giá thuê (VND/giờ)</label>
        <input type="number" th:field="*{pricePerHour}" class="form-control"/>
    </div>

    <!-- Kích thước -->
    <div class="mb-3">
        <label class="form-label">Kích thước</label>
        <input type="text" th:field="*{fieldSize}" class="form-control"/>
    </div>

    <!-- Loại mặt sân -->
    <div class="mb-3">
        <label class="form-label">Loại mặt sân</label>
        <input type="text" th:field="*{surfaceType}" class="form-control"/>
    </div>

    <!-- Đèn -->
    <div class="mb-3">
        <label class="form-label">Đèn</label>
        <select th:field="*{lightsAvailable}" class="form-control">
            <option th:value="true">Có</option>
            <option th:value="false">Không</option>
        </select>
    </div>

    <!-- Trạng thái -->
    <div class="mb-3">
        <label class="form-label">Trạng thái</label>
        <select th:field="*{status}" class="form-control">
            <option th:value="true">Hoạt động</option>
            <option th:value="false">Ngừng hoạt động</option>
        </select>
    </div>

    <!-- Địa điểm -->
    <div class="mb-3">
        <label class="form-label">Địa điểm</label>
        <select th:field="*{venue}" class="form-control">
            <option value="">-- Chọn địa điểm --</option>
            <option th:each="venue : ${venues}"
                    th:value="${venue.venueId}"
                    th:selected="${cour.venue != null and venue.venueId == cour.venue.venueId}"
                    th:text="${venue.venueName}">
            </option>
        </select>
    </div>

    <!-- Upload ảnh -->
    <div class="mb-3">
        <label class="form-label">Ảnh sân bóng</label>
        <input type="file" name="file" class="form-control" onchange="previewImage(event)"/>

        <!-- Hiển thị ảnh cũ hoặc ảnh mới chọn -->
        <div class="mt-2">
            <p>Ảnh hiện tại </p>
            <img id="preview"
                 th:src="${cour.image != null} ? @{'/uploads/avatars/' + ${cour.image}} : @{/img/no-image.png}"
                 alt="Ảnh sân"
                 width="200"
                 class="img-thumbnail"/>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>
    <a th:href="@{/cour}" class="btn btn-secondary">Hủy</a>
</form>

<!-- JS preview ảnh mới chọn -->
<script>
    function previewImage(event) {
        const file = event.target.files[0];
        if (file) {
            const preview = document.getElementById('preview');
            preview.src = URL.createObjectURL(file);
        }
    }
</script>

</body>
</html>
