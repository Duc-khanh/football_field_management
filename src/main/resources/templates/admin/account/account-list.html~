<script th:src="@{/js/homeAdmin.js}"></script>



<script>
    document.addEventListener("DOMContentLoaded", function () {

        var tooltipTriggerList = Array.from(document.querySelectorAll('[title]'));
        tooltipTriggerList.forEach(function (el) {
            // assumes bootstrap bundle is loaded and `bootstrap.Tooltip` is available
            new bootstrap.Tooltip(el);
        });

        // Confirm khi toggle
        document.querySelectorAll(".toggle-btn").forEach(btn => {
            btn.addEventListener("click", function (e) {
                const status = this.getAttribute("data-status") === "true";
                const action = status ? "khóa" : "mở khóa";
                if (!confirm(`Bạn có chắc chắn muốn ${action} tài khoản này không?`)) {
                    e.preventDefault();
                }
            });
        });

        const keywordInput = document.getElementById("keywordInput");
        const searchForm = document.getElementById("searchForm");
        let typingTimer;

        keywordInput.addEventListener("keyup", function () {
            clearTimeout(typingTimer);
            typingTimer = setTimeout(() => {
                searchForm.submit();
            }, 1500); // 2000ms = 2 giây
        });

        keywordInput.addEventListener("keydown", function () {
            clearTimeout(typingTimer);
        });
    });
</script>


