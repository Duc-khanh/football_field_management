<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Chi tiết User</title>
    <meta charset="UTF-8">
</head>
<body>
<h2>Thông tin chi tiết User</h2>

<p><b>ID:</b> <span th:text="${account.account_id}"></span></p>
<p><b>Full Name:</b> <span th:text="${account.full_name}"></span></p>
<p><b>Email:</b> <span th:text="${account.email}"></span></p>
<p><b>Phone:</b> <span th:text="${account.phone}"></span></p>
<p><b>Address:</b> <span th:text="${account.address}"></span></p>
<p><b>Status:</b> <span th:text="${account.status}"></span></p>

<h3>Roles:</h3>
<ul>
    <li th:each="role : ${account.roles}" th:text="${role.role_name}"></li>
</ul>

<a href="/accounts">Quay lại danh sách</a>
</body>
</html>
